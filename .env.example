PORT=3000
SESSION_SECRET=your-super-secret-session-key-change-me

# Google OAuth — https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# Email (SMTP) — для уведомлений о заказах
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
ADMIN_EMAIL=admin@scentforge.ru

# ИИ-консультант — Google Gemini (бесплатно): https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Или Groq (бесплатно, быстрый): https://console.groq.com/keys
GROQ_API_KEY=

# Или OpenAI: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Админ Google ID (получите после первого входа через Google)
ADMIN_GOOGLE_ID=

# Внешняя CRM — заказы отправляются автоматически при оформлении
# Ссылка на панель CRM (видна только администратору в меню)
CRM_URL=https://your-crm.example.com

# Webhook (универсально: Zapier, Make, n8n, Bitrix24 и др.)
CRM_WEBHOOK_URL=
CRM_WEBHOOK_SECRET=

# Или нативная интеграция с amoCRM
# CRM_PROVIDER=amocrm
# AMOCRM_SUBDOMAIN=yourcompany
# AMOCRM_ACCESS_TOKEN=your-long-lived-token
# AMOCRM_PIPELINE_ID=
