PORT=3000
SESSION_SECRET=your-super-secret-session-key-change-me

# Google OAuth — https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# Email (SMTP) — для уведомлений о заказах
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
ADMIN_EMAIL=admin@scentforge.ru

# ИИ-консультант — Google Gemini (бесплатно): https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Или Groq (бесплатно, быстрый): https://console.groq.com/keys
GROQ_API_KEY=

# Или OpenAI: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Админ Google ID (получите после первого входа через Google)
ADMIN_GOOGLE_ID=

# Внешняя CRM — настраивается автоматически при запуске сервера.
# Админ открывает CRM через меню «CRM» на сайте (отдельная панель /crm/).
# Опционально: свой ключ доступа (иначе генерируется из SESSION_SECRET)
# CRM_ACCESS_TOKEN=

# Опционально: сторонняя CRM вместо встроенной панели
# CRM_PROVIDER=amocrm
# CRM_URL=https://yourcompany.amocrm.ru
# AMOCRM_SUBDOMAIN=yourcompany
# AMOCRM_ACCESS_TOKEN=
